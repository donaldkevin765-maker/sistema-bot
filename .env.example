# ──────────────────────────────────────────────
# SISTEMA BOT — Configurazione Ambiente
# ──────────────────────────────────────────────
# Copia questo file in .env e modifica i valori

# Firebase (obbligatorio per controllo remoto)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Telegram (opzionale, per notifiche alert/ban/captcha)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ADB (configurazione di default)
ADB_DEVICE_SERIAL=

# Sicurezza (cambia in produzione!)
COOKIE_ENCRYPTION_KEY=cambia-questa-chiave-con-una-sicura

# Agente
AGENT_ID=

# YouTube warmup
WATCH_TIME_MIN=120
WATCH_TIME_MAX=240
DEFAULT_KEYWORD=music

# TikTok warmup
TIKTOK_WATCH_TIME_MIN=60
TIKTOK_WATCH_TIME_MAX=180
TIKTOK_DEFAULT_HASHTAG=music

# Instagram warmup
INSTAGRAM_WATCH_TIME_MIN=30
INSTAGRAM_WATCH_TIME_MAX=90
INSTAGRAM_DEFAULT_HASHTAG=music
