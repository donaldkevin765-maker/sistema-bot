{
  "env": { "node": true, "es2021": true },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": { "ecmaVersion": "latest", "sourceType": "module" },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "error",
    "prefer-const": "warn",
    "no-var": "error"
  },
  "ignorePatterns": ["node_modules", "dist", "build", ".next"]
}
